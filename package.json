{
	"name": "counterledger",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"license": "GPL-3.0-only",
	"engines": {
		"node": ">=24",
		"npm": ">=11"
	},
	"scripts": {
		"dev": "next dev -p 3200",
		"dev:tunnel": "ngrok http 3200",
		"build": "next build",
		"start": "next start",
		"lint": "eslint",
		"reinstall": "rm -rf node_modules .next package-lock.json && npm i",
		"update:latest": "npx -y npm-check-updates -u && npm i && npm dedupe && npm outdated && npm ls",
		"biome:check": "npx biome check",
		"biome:check:write": "npx biome check --write",
		"biome:check:write:unsafe": "npx biome check --write --unsafe",
		"vercel:env:pull": "vercel env pull .env.local",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push"
	},
	"dependencies": {
		"@neondatabase/serverless": "^1.1.0",
		"better-auth": "^1.6.9",
		"drizzle-orm": "^0.45.2",
		"jose": "^6.2.2",
		"next": "16.2.4",
		"plaid": "^42.1.0",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"react-plaid-link": "^4.1.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^25",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"dotenv": "^17.4.2",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.2.1",
		"eslint-config-next": "16.2.4",
		"tailwindcss": "^4",
		"typescript": "^6"
	}
}
